# Completed 6555 alignments
#
# Throughput: naligns= 6555 naligns/cpusec= 134.766
# Alignfastas : 6555 alignments, elapsed time 48.640 (cpu seconds), 48 (real seconds), throughput 134.765625 alignments/cpusec
#! /usr/bin/python3
''' transform a set of alignfastas records into data to test Aclust read-through of multiple ALIGNFASTAS output files '''

import hashlib

lines = [line.strip() for line in open('alignfastas_04_04.out', 'r').readlines()]

ops = [open('AA.aln', 'w'), open('AB.aln', 'w'), open('BB.aln', 'w')]

i = 0
for line in lines:
	if len(line) == 0 or line[0] == '#':
		for op in ops:
			op.write(line + '\n')
	else:
		word = line.split()
		line = line.replace(word[1], hashlib.md5(str(word[1]).encode('utf-8')).hexdigest())
		line = line.replace(word[3], hashlib.md5(str(word[3]).encode('utf-8')).hexdigest())
		ops[i%3].write(line + '\n')
		i += 1
# add some random stuff after the actual data and program output
with open('xform.py', 'r') as fp:
	for line in fp.readlines():
		for op in ops:
			op.write(line)

fp.close()

for op in ops:
	op.close()
